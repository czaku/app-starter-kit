# AppStarterKit — Environment Variables
# Copy to backend/.env and fill in values

# ── Server ────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database ──────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/appstarterkit_dev

# ── Authentication ────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=your-32-char-minimum-secret-here
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY_DAYS=30
MAGIC_LINK_EXPIRY_MINUTES=15

# ── Redis (BullMQ queues) ─────────────
REDIS_URL=redis://localhost:6379

# ── Email (SMTP) ──────────────────────
# Leave blank to use console logging in development
SMTP_HOST=smtp.yourmailprovider.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourapp.com

# ── App Version Enforcement ───────────
APP_VERSION_IOS_CURRENT=1.0.0
APP_VERSION_IOS_MINIMUM=1.0.0
APP_VERSION_ANDROID_CURRENT=1.0.0
APP_VERSION_ANDROID_MINIMUM=1.0.0

# ── Firebase (optional, for push notifications) ──
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
